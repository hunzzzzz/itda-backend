<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.moira.itda.domain.profile.mapper.ProfileMapper">
    <select id="selectUser" resultType="com.moira.itda.domain.profile.dto.response.ProfileResponse">
        SELECT
               A.id
             , A.role
             , A.status
             , A.type
             , A.name
             , A.nickname
             , A.phone
             , A.image_url
             , A.email
             , A.last_login_at
             , A.created_at
        FROM USER A
        WHERE A.id = #{userId}
    </select>
</mapper>