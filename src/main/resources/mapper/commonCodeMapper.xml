<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.moira.itda.domain.common.mapper.CommonCodeMapper">
    <!-- 공통 코드 존재 여부 확인 -->
    <select id="selectCommonCodeKeyChk">
        SELECT COUNT(code_key) FROM COMMON_CODE WHERE code_key = #{key}
    </select>

    <!-- 공통 코드 조회 -->
    <select id="selectCommonCodeDetailList" resultType="com.moira.itda.domain.common.dto.CommonCodeResponse">
        SELECT eng_name, kor_name FROM COMMON_CODE_DETAIL WHERE code_key = #{key}
    </select>
</mapper>